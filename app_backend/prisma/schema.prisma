generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resumes  Resume[]
  analyses Analysis[]
  messages Message[]
}

model Resume {
  id         String   @id @default(uuid())
  userId     String
  pdf_url    String
  uploadedAt DateTime @default(now())

  user     User       @relation(fields: [userId], references: [id])
  analyses Analysis[]
}

model Analysis {
  id         String   @id @default(uuid())
  userId     String
  resumeId   String
  jobTitle   String
  atsScore   Int
  fullResult Json
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  resume Resume @relation(fields: [resumeId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  userId    String
  resumeId  String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
